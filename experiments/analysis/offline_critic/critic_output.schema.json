{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Offline coordination critic result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "critic_id",
    "trial_id",
    "window_end_s",
    "verdict",
    "imbalance_types",
    "confidence",
    "observations",
    "agent_assessments",
    "manager_advisory",
    "limitations"
  ],
  "properties": {
    "critic_id": {"type": "string"},
    "trial_id": {"type": "string"},
    "window_end_s": {"type": "number"},
    "verdict": {
      "type": "string",
      "enum": ["imbalance_detected", "no_imbalance_observed", "unknown"]
    },
    "imbalance_types": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "workload_concentration",
          "duplicated_scope",
          "idle_while_peer_overloaded",
          "blocked_dependency",
          "failed_handoff",
          "role_action_mismatch",
          "conflicting_world_actions"
        ]
      }
    },
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "observations": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["certainty", "claim", "evidence"],
        "properties": {
          "certainty": {"type": "string", "enum": ["O", "I"]},
          "claim": {"type": "string", "maxLength": 360},
          "evidence": {
            "type": "array",
            "minItems": 1,
            "maxItems": 6,
            "items": {"type": "string"}
          }
        }
      }
    },
    "agent_assessments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["agent", "load_state", "summary", "evidence"],
        "properties": {
          "agent": {"type": "string"},
          "load_state": {
            "type": "string",
            "enum": ["underloaded", "proportionate", "overloaded", "blocked", "unknown"]
          },
          "summary": {"type": "string", "maxLength": 300},
          "evidence": {
            "type": "array",
            "maxItems": 6,
            "items": {"type": "string"}
          }
        }
      }
    },
    "manager_advisory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["send", "priority", "message"],
      "properties": {
        "send": {"type": "boolean"},
        "priority": {
          "type": "string",
          "enum": ["none", "monitor", "rebalance", "unblock", "stop_conflict"]
        },
        "message": {"type": "string", "maxLength": 280}
      }
    },
    "limitations": {
      "type": "array",
      "maxItems": 4,
      "items": {"type": "string", "maxLength": 260}
    }
  }
}
